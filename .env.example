# GitHub — fine-grained PAT with read-only access to public profile/repos.
# Used by /api/github for live stats, top repos, languages, and contributions.
GITHUB_TOKEN=

# Resend — used by /api/contact to email contact-form submissions.
# Get a key at https://resend.com
RESEND_API_KEY=
# Where contact-form messages are delivered:
CONTACT_TO_EMAIL=ashar.builds@gmail.com
# Optional verified sender; defaults to Resend's onboarding sender if unset:
CONTACT_FROM_EMAIL=
